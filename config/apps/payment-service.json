{
  "endpoints": [
    {
      "id": "get_payment",
      "method": "GET",
      "url": "/api/v1/payments/{paymentId}",
      "dataFile": "data/payment_ids.csv",
      "thinkTime": { "min": 1, "max": 3 },
      "weight": 50,
      "checks": { "status": 200 }
    },
    {
      "id": "create_payment",
      "method": "POST",
      "url": "/api/v1/payments",
      "body": { "orderId": "{orderId}", "amount": "{amount}", "currency": "{currency}" },
      "dataFile": "data/payment_payload.csv",
      "thinkTime": { "min": 3, "max": 6 },
      "weight": 50,
      "checks": { "status": 201 }
    }
  ]
}
