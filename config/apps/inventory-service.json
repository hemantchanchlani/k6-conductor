{
  "endpoints": [
    {
      "id": "get_stock",
      "method": "GET",
      "url": "/api/v1/inventory/{productId}/stock",
      "dataFile": "data/product_ids.csv",
      "thinkTime": { "min": 1, "max": 3 },
      "weight": 60,
      "checks": { "status": 200 }
    },
    {
      "id": "update_stock",
      "method": "PATCH",
      "url": "/api/v1/inventory/{productId}/stock",
      "body": { "quantity": "{quantity}", "operation": "{operation}" },
      "dataFile": "data/inventory_updates.csv",
      "thinkTime": { "min": 2, "max": 4 },
      "weight": 40,
      "checks": { "status": 200 }
    }
  ]
}
